-- UI Library Setup
local Library = {}
local tabs = {}
local currentTab = nil

function Library:CreateTab(name)
    local tBtn = Instance.new("TextButton")
    tBtn.Size = UDim2.new(0, 100, 1, 0)
    tBtn.BackgroundColor3 = C.ElementBG
    tBtn.Text = name
    tBtn.TextColor3 = C.Muted
    tBtn.Font = Enum.Font.GothamSemibold
    tBtn.TextSize = 13
    tBtn.AutoButtonColor = false
    tBtn.Parent = TabScroll
    round(tBtn, 6)
    
    -- Auto size tab button to fit text
    tBtn.Size = UDim2.new(0, tBtn.TextBounds.X + 24, 1, 0)
    
    local Page = Instance.new("ScrollingFrame")
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.ScrollBarThickness = 2
    Page.ScrollBarImageColor3 = C.Accent
    Page.CanvasSize = UDim2.new(0, 0, 0, 0)
    Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Page.Visible = false
    Page.Parent = ContentArea
    
    local PList = Instance.new("UIListLayout")
    PList.SortOrder = Enum.SortOrder.LayoutOrder
    PList.Padding = UDim.new(0, 8)
    PList.Parent = Page
    
    local PPad = Instance.new("UIPadding")
    PPad.PaddingLeft = UDim.new(0, 12)
    PPad.PaddingRight = UDim.new(0, 12)
    PPad.PaddingTop = UDim.new(0, 12)
    PPad.PaddingBottom = UDim.new(0, 12)
    PPad.Parent = Page
    
    local tabInfo = {Btn = tBtn, Page = Page}
    table.insert(tabs, tabInfo)
    
    tBtn.Activated:Connect(function()
        for _, v in ipairs(tabs) do
            v.Btn.TextColor3 = C.Muted
            v.Btn.BackgroundColor3 = C.ElementBG
            v.Page.Visible = false
        end
        tBtn.TextColor3 = C.Text
        tBtn.BackgroundColor3 = C.Accent
        Page.Visible = true
    end)
    
    if #tabs == 1 then
        tBtn.TextColor3 = C.Text
        tBtn.BackgroundColor3 = C.Accent
        Page.Visible = true
    end
    
    local Elements = {}
    
    -- Creates a uniformly aligned Section Header
    function Elements:CreateSection(title)
        local sec = Instance.new("Frame")
        sec.Size = UDim2.new(1, 0, 0, 25)
        sec.BackgroundTransparency = 1
        sec.Parent = Page
        local lbl = createLabel(sec, title, Enum.TextXAlignment.Left, Enum.Font.GothamBold, 12, C.Accent)
        lbl.Size = UDim2.new(1, 0, 1, 0)
    end

    -- 100% Width Mobile Friendly Toggle
    function Elements:CreateToggle(title, default, callback)
        local state = default or false
        local tgl = Instance.new("TextButton")
        tgl.Size = UDim2.new(1, 0, 0, 45) -- Standard touch height
        tgl.BackgroundColor3 = C.ElementBG
        tgl.Text = ""
        tgl.AutoButtonColor = false
        tgl.Parent = Page
        round(tgl, 8)
        
        local lbl = createLabel(tgl, title, Enum.TextXAlignment.Left, Enum.Font.Gotham, 13, C.Text)
        lbl.Size = UDim2.new(1, -60, 1, 0); lbl.Position = UDim2.new(0, 15, 0, 0)
        
        local switch = Instance.new("Frame")
        switch.Size = UDim2.new(0, 40, 0, 22)
        switch.AnchorPoint = Vector2.new(1, 0.5)
        switch.Position = UDim2.new(1, -15, 0.5, 0)
        switch.BackgroundColor3 = state and C.Accent or C.TopBar
        switch.Parent = tgl
        round(switch, 11)
        
        local circle = Instance.new("Frame")
        circle.Size = UDim2.new(0, 16, 0, 16)
        circle.AnchorPoint = Vector2.new(0, 0.5)
        circle.Position = UDim2.new(0, state and 21 or 3, 0.5, 0)
        circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        circle.Parent = switch
        round(circle, 8)
        
        tgl.Activated:Connect(function()
            state = not state
            TweenService:Create(switch, TweenInfo.new(0.2), {BackgroundColor3 = state and C.Accent or C.TopBar}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2), {Position = UDim2.new(0, state and 21 or 3, 0.5, 0)}):Play()
            if callback then callback(state) end
        end)
    end
    
    -- 100% Width Mobile Friendly Dropdown
    function Elements:CreateDropdown(title, list, default, callback)
        local drop = Instance.new("Frame")
        drop.Size = UDim2.new(1, 0, 0, 45)
        drop.BackgroundColor3 = C.ElementBG
        drop.ClipsDescendants = true
        drop.Parent = Page
        round(drop, 8)
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 45)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.Parent = drop
        
        local lbl = createLabel(btn, title .. ": " .. (default or "None"), Enum.TextXAlignment.Left, Enum.Font.Gotham, 13, C.Text)
        lbl.Size = UDim2.new(1, -40, 1, 0); lbl.Position = UDim2.new(0, 15, 0, 0)
        
        local icon = createLabel(btn, "+", Enum.TextXAlignment.Right, Enum.Font.GothamBold, 16, C.Accent)
        icon.Size = UDim2.new(0, 20, 1, 0); icon.Position = UDim2.new(1, -25, 0, 0)
        
        local listFrame = Instance.new("Frame")
        listFrame.Size = UDim2.new(1, 0, 1, -45)
        listFrame.Position = UDim2.new(0, 0, 0, 45)
        listFrame.BackgroundTransparency = 1
        listFrame.Parent = drop
        
        local dList = Instance.new("UIListLayout")
        dList.SortOrder = Enum.SortOrder.LayoutOrder
        dList.Parent = listFrame
        
        local open = false
        btn.Activated:Connect(function()
            open = not open
            local targetSize = open and 45 + (#list * 35) or 45
            icon.Text = open and "-" or "+"
            TweenService:Create(drop, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, targetSize)}):Play()
        end)
        
        for _, item in ipairs(list) do
            local iBtn = Instance.new("TextButton")
            iBtn.Size = UDim2.new(1, 0, 0, 35)
            iBtn.BackgroundColor3 = C.ElementBG
            iBtn.Text = "  " .. item
            iBtn.TextColor3 = C.Muted
            iBtn.Font = Enum.Font.Gotham
            iBtn.TextSize = 13
            iBtn.TextXAlignment = Enum.TextXAlignment.Left
            iBtn.BorderSizePixel = 0
            iBtn.Parent = listFrame
            
            iBtn.Activated:Connect(function()
                lbl.Text = title .. ": " .. item
                open = false
                icon.Text = "+"
                TweenService:Create(drop, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 45)}):Play()
                if callback then callback(item) end
            end)
        end
    end

    function Elements:CreateSlider(title, min, max, default, callback)
        local slider = Instance.new("Frame")
        slider.Size = UDim2.new(1, 0, 0, 60)
        slider.BackgroundColor3 = C.ElementBG
        slider.Parent = Page
        round(slider, 8)
        
        local lbl = createLabel(slider, title .. ": " .. default, Enum.TextXAlignment.Left, Enum.Font.Gotham, 13, C.Text)
        lbl.Size = UDim2.new(1, -30, 0, 30); lbl.Position = UDim2.new(0, 15, 0, 0)
        
        local bg = Instance.new("Frame")
        bg.Size = UDim2.new(1, -30, 0, 6)
        bg.Position = UDim2.new(0, 15, 0, 38)
        bg.BackgroundColor3 = C.TopBar
        bg.Parent = slider
        round(bg, 3)
        
        local fill = Instance.new("Frame")
        local pct = math.clamp((default - min) / (max - min), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        fill.BackgroundColor3 = C.Accent
        fill.Parent = bg
        round(fill, 3)
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 1, 20)
        btn.Position = UDim2.new(0, 0, 0, -10)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.Parent = bg
        
        local drag = false
        btn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = true end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = false end end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                local x = math.clamp((i.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (max - min) * x)
                fill.Size = UDim2.new(x, 0, 1, 0)
                lbl.Text = title .. ": " .. val
                if callback then callback(val) end
            end
        end)
    end
    
    return Elements
end

