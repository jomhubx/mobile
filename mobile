local function createLabel(parent, text, align, font, size, color)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.Font = font
    lbl.TextSize = size
    lbl.TextColor3 = color
    lbl.TextXAlignment = align
    lbl.Parent = parent
    return lbl
