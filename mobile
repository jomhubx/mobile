local function parseLevel(val)
    if type(val) == "number" then return val end
    if type(val) == "string" then
        local num = string.match(val, "%d+")
        if num then return tonumber(num) end
    end
    return 1
end

local function getCurrentLevel()
    local data = LocalPlayer:FindFirstChild("Data")
    if data and data:FindFirstChild("Level") then return parseLevel(data.Level.Value) end
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats and leaderstats:FindFirstChild("Level") then return parseLevel(leaderstats.Level.Value) end
    if LocalPlayer:GetAttribute("Level") then return parseLevel(LocalPlayer:GetAttribute("Level")) end
    return 1
end

local function SmartTeleport(targetCFrame)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return end
    
    local dist = (hrp.Position - targetCFrame.Position).Magnitude
    if dist < 50 then hrp.CFrame = targetCFrame; return end
    
    if S.teleportMode == "Instant" then
        if dist > 500 then pcall(function() LocalPlayer:RequestStreamAroundAsync(targetCFrame.Position) end); task.wait(0.1) end
        hrp.CFrame = targetCFrame
        return
    end
    
    local speed = 150
    local timeToReach = math.max(0.1, dist / speed)
    
    local fbv = hrp:FindFirstChild("JomFarmBV")
    if fbv then fbv:Destroy() end
    
    local bv = hrp:FindFirstChild("JomTeleportBV")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "JomTeleportBV"; bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); bv.Parent = hrp
    end
    
    local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    
    local conn = RunService.Heartbeat:Connect(function()
        if not (S.AutoLevelActive or S.AutoFarmActive) or not char or hum.Health <= 0 then tween:Cancel() end
    end)
    
    tween:Play()
    local startTick = tick()
    while tween.PlaybackState == Enum.PlaybackState.Playing do
        if tick() - startTick > timeToReach + 2 then tween:Cancel(); break end
        task.wait()
    end
    if conn then conn:Disconnect() end
    if bv then bv:Destroy() end
end

local function getFarmPosition(targetRoot, baseDistance, posType)
    local enemyPos = targetRoot.Position
    local tpPos = enemyPos
    
    if posType == "Above" then 
        tpPos = enemyPos + Vector3.new(0, baseDistance, 0)
        return CFrame.new(tpPos) * CFrame.Angles(math.rad(0 - 90), 0, 0)
    else
        local lookVec = targetRoot.CFrame.LookVector
        local angle = math.atan2(0 - lookVec.X, 0 - lookVec.Z)
        local flatCF = CFrame.new(enemyPos) * CFrame.Angles(0, angle, 0)
        
        tpPos = (flatCF * CFrame.new(0, 0, baseDistance)).Position
        return CFrame.lookAt(tpPos, enemyPos)
    end
end

local function getWeaponsToUse()
    local weapons = {}
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    local function checkList(list)
        for _, name in ipairs(list) do
            local w = (char and char:FindFirstChild(name)) or (bp and bp:FindFirstChild(name))
            if w then return w end
        end
        return nil
    end
    if S.autoMelee then local w = checkList(MELEE_LIST); if w then table.insert(weapons, w) end end
    if S.autoSword then local w = checkList(SWORD_LIST); if w then table.insert(weapons, w) end end
    if S.autoFruit then local w = checkList(FRUIT_LIST); if w then table.insert(weapons, w) end end
    
    -- Failsafe: if nothing matched but they want to farm, grab the first available tool!
    if #weapons == 0 and bp then
        local firstTool = bp:FindFirstChildOfClass("Tool") or (char and char:FindFirstChildOfClass("Tool"))
        if firstTool then table.insert(weapons, firstTool) end
    end
    return weapons
end

local function executeAttacks(targetObj)
    local dynCombatSys = ReplicatedStorage:FindFirstChild("CombatSystem")
    local dynRequestHit = dynCombatSys and dynCombatSys:FindFirstChild("Remotes") and dynCombatSys.Remotes:FindFirstChild("RequestHit")
    local dynRemoteEv = ReplicatedStorage:FindFirstChild("RemoteEvents")
    local dynCombatRemote = dynRemoteEv and dynRemoteEv:FindFirstChild("CombatRemote")
    local dynKatanaRemote = dynRemoteEv and dynRemoteEv:FindFirstChild("KatanaCombatRemote")
    local dynAbilSys = ReplicatedStorage:FindFirstChild("AbilitySystem")
    local dynRequestAbil = dynAbilSys and dynAbilSys:FindFirstChild("Remotes") and dynAbilSys.Remotes:FindFirstChild("RequestAbility")

    if dynRequestHit then pcall(function() dynRequestHit:FireServer(targetObj) end) end
    if dynCombatRemote then pcall(function() dynCombatRemote:FireServer("Punch", targetObj) end) end
    if dynKatanaRemote then pcall(function() dynKatanaRemote:FireServer("Punch", targetObj) end) end
    if dynRequestAbil then
        if S.autoSkills["Skill Z"] then pcall(function() dynRequestAbil:FireServer(1) end) end
        if S.autoSkills["Skill X"] then pcall(function() dynRequestAbil:FireServer(2) end) end
        if S.autoSkills["Skill C"] then pcall(function() dynRequestAbil:FireServer(3) end) end
        if S.autoSkills["Skill V"] then pcall(function() dynRequestAbil:FireServer(4) end) end
        if S.autoSkills["Skill F"] then pcall(function() dynRequestAbil:FireServer(5) end) end
    end
end

local function getPortalForMob(mobName)
    if not mobName or mobName == "" then return nil end
    local cleanName = string.gsub(mobName, "%d+$", "")
    local ln = string.gsub(string.lower(cleanName), "%s+", "")
    
    local PORTAL_MAP = {
        thief = "Starter", thiefboss = "Starter",
        monkey = "Jungle", monkeyboss = "Jungle",
        desertbandit = "Desert", desertboss = "Desert",
        frostrogue = "Snow", winterwarden = "Snow", snowboss = "Snow",
        hollow = "HollowIsland",
        strongsorcerer = "Shinjuku", curse = "Shinjuku",
        slimewarrior = "Slime", slime = "Slime", academyteacher = "Academy",
        swordsman = "Judgement", quincy = "SoulDominion",
        ninja = "Ninja", arenafighter = "Lawless"
    }
    
    if PORTAL_MAP[ln] then return PORTAL_MAP[ln] end
    local lnNoBoss = string.gsub(ln, "boss", "")
    if PORTAL_MAP[lnNoBoss] then return PORTAL_MAP[lnNoBoss] end
    
    for _, tier in ipairs(PROGRESSION_MAP) do
        if string.lower(string.gsub(tier.Mob, "%s+", "")) == ln or string.lower(string.gsub(tier.Mob, "%s+", "")) == lnNoBoss then 
            return tier.Portal 
        end
    end
    return nil
end

local function isMobTarget(npc, tMob)
    if not npc or not npc.Name then return false end
    local cleanName = npc.Name:gsub("%d+$", ""):match("^%s*(.-)%s*$")
    local noSpaceName = cleanName and string.gsub(cleanName, "%s+", "") or ""
    
    if not tMob or tMob == "" then return false end
    local noSpaceTarget = string.gsub(tMob, "%s+", "")
    if string.lower(noSpaceName) == string.lower(noSpaceTarget) then return true end
    
    if string.find(string.lower(noSpaceTarget), "boss") then
        local strippedTarget = string.gsub(string.lower(noSpaceTarget), "boss", "")
        if string.lower(noSpaceName) == strippedTarget then
            local hum = npc:FindFirstChild("Humanoid")
            if hum and hum.MaxHealth > 5000 then return true end
        end
    end
    return false
end

-- Required Noclip logic to safely Tween
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if (S.AutoLevelActive or S.AutoFarmActive) and char then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    elseif char and char:FindFirstChild("HumanoidRootPart") then
        local fbv = char.HumanoidRootPart:FindFirstChild("JomFarmBV")
        if fbv then fbv:Destroy() end
        local tbv = char.HumanoidRootPart:FindFirstChild("JomTeleportBV")
        if tbv then tbv:Destroy() end
    end
end)

-- AUTO LEVEL & FARM LOOP (Simplified Quest Logic)
local currentTargetCrystal = nil
task.spawn(function()
    while task.wait() do
        if not S.AutoLevelActive and not S.AutoFarmActive then 
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local fbv = hrp:FindFirstChild("JomFarmBV")
                if fbv then fbv:Destroy() end
            end
            task.wait(0.5)
            continue 
        end
        
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end
        
        local fbv = hrp:FindFirstChild("JomFarmBV")
        if not fbv then
            fbv = Instance.new("BodyVelocity"); fbv.Name = "JomFarmBV"; fbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); fbv.Velocity = Vector3.zero; fbv.Parent = hrp
        end
        
        local activeMob = ""
        local activeQuest = ""
        
        local dynRemotes = ReplicatedStorage:FindFirstChild("Remotes")
        local dynTpPortal = dynRemotes and dynRemotes:FindFirstChild("TeleportToPortal")
        local dynEvents = ReplicatedStorage:FindFirstChild("RemoteEvents")
        local dynAbandon = dynEvents and dynEvents:FindFirstChild("QuestAbandon")
        local dynAccept = dynEvents and dynEvents:FindFirstChild("QuestAccept")
        
        if S.AutoLevelActive then
            local myLevel = getCurrentLevel()
            local bestTier = PROGRESSION_MAP[1]
            for _, tier in ipairs(PROGRESSION_MAP) do
                if myLevel >= tier.Level then bestTier = tier else break end
            end
            activeMob = bestTier.Mob
            activeQuest = bestTier.Quest
            
            -- 1. Instantly teleport to new island via game remote
            if S.lastPortal ~= bestTier.Portal and bestTier.Portal then
                if dynTpPortal then
                    pcall(function() dynTpPortal:FireServer(bestTier.Portal) end)
                    S.lastPortal = bestTier.Portal
                    task.wait(3) -- Wait for teleport to process & chunks to load
                    continue
                end
            end
            
            -- 2. Bypass & Accept Quest Logic (No Turn-In needed)
            local questUI = LocalPlayer:FindFirstChild("PlayerGui") and LocalPlayer.PlayerGui:FindFirstChild("QuestUI")
            local hasQuest = questUI and questUI:FindFirstChild("Quest") and questUI.Quest.Visible
            
            if S.lastAutoQuest ~= bestTier.Quest then
                if dynAbandon then
                    pcall(function() dynAbandon:FireServer("repeatable") end)
                    pcall(function() dynAbandon:FireServer("Abandon") end)
                    pcall(function() dynAbandon:FireServer("repeatable") end)
                    pcall(function() dynAbandon:FireServer() end)
                end
                if questUI and questUI:FindFirstChild("Quest") then questUI.Quest.Visible = false end
                task.wait(0.5)
                if dynAccept then
                    pcall(function() dynAccept:FireServer(bestTier.Quest) end)
                end
                S.lastAutoQuest = bestTier.Quest
                task.wait(0.5)
                continue
            elseif not hasQuest then
                -- Quest auto-completed by reaching kill requirements -> Accept it again
                if dynAccept then
                    pcall(function() dynAccept:FireServer(bestTier.Quest) end)
                end
                task.wait(0.5)
            end
        else
            activeMob = S.selectedMob
            local targetPortal = getPortalForMob(activeMob)
            if targetPortal and S.lastPortal ~= targetPortal and dynTpPortal then
                pcall(function() dynTpPortal:FireServer(targetPortal) end)
                S.lastPortal = targetPortal
                task.wait(3)
                continue
            end
        end

        -- 3. Auto Set Spawn (Built-in for Auto Level)
        if S.AutoLevelActive and hrp then
            local targetCrystal = currentTargetCrystal
            
            if not char:GetAttribute("LastSpawnSearch") or tick() - char:GetAttribute("LastSpawnSearch") > 3 then
                char:SetAttribute("LastSpawnSearch", tick())
                local closestPrompt, minDist = nil, math.huge
                for _, v in ipairs(Workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") and v.Name == "CheckpointPrompt" then
                        if v.Parent and v.Parent:IsA("BasePart") then
                            local d = (hrp.Position - v.Parent.Position).Magnitude
                            -- Only target checkpoints on the current island
                            if d < minDist and d < 3000 then minDist = d; closestPrompt = v end
                        end
                    end
                end
                
                if closestPrompt and closestPrompt.Parent then
                    local posKey = math.floor(closestPrompt.Parent.Position.X) .. "_" .. math.floor(closestPrompt.Parent.Position.Z)
                    if not S.claimedSpawns[posKey] then
                        currentTargetCrystal = closestPrompt
                    else
                        currentTargetCrystal = nil
                    end
                else
                    currentTargetCrystal = nil
                end
            end
            
            targetCrystal = currentTargetCrystal
            if targetCrystal and targetCrystal.Parent then
                local part = targetCrystal.Parent
                if (hrp.Position - part.Position).Magnitude > 15 then
                    SmartTeleport(CFrame.new(part.Position + Vector3.new(0, 3, 4)))
                else
                    hrp.CFrame = CFrame.lookAt(part.Position + Vector3.new(0, 3, 4), part.Position)
                    hrp.Velocity = Vector3.zero
                    local posKey = math.floor(part.Position.X) .. "_" .. math.floor(part.Position.Z)
                    S.lastTargetedCrystalPos = posKey
                    task.wait(0.2)
                    
                    pcall(function()
                        targetCrystal.RequiresLineOfSight = false
                        targetCrystal.MaxActivationDistance = 50
                        targetCrystal.Style = Enum.ProximityPromptStyle.Custom
                        task.wait(0.05)
                        if fireproximityprompt then 
                            fireproximityprompt(targetCrystal, 1, true)
                        else 
                            targetCrystal:InputHoldBegin(); task.wait(targetCrystal.HoldDuration + 0.1); targetCrystal:InputHoldEnd() 
                        end
                        task.delay(1.5, function()
                            if targetCrystal and targetCrystal.Parent then
                                targetCrystal.Style = Enum.ProximityPromptStyle.Default
                            end
                        end)
                    end)
                    task.wait(0.5)
                    S.claimedSpawns[posKey] = true
                    currentTargetCrystal = nil
                end
                continue -- Wait until checkpoint is claimed before going to target
            elseif targetCrystal and not targetCrystal.Parent then
                currentTargetCrystal = nil
            end
        end
        
        -- 4. Enemy Targeting Logic     
        local target = nil
        local minDist = math.huge
        local unloadedMobPos = nil
        local currentNPCs = Workspace:FindFirstChild("NPCs")
        
        if currentNPCs then
            for _, npc in ipairs(currentNPCs:GetChildren()) do
                if npc:IsA("Model") and isMobTarget(npc, activeMob) then
                    local nHum = npc:FindFirstChild("Humanoid")
                    local nRoot = npc:FindFirstChild("HumanoidRootPart")
                    if nHum and nHum.Health > 0 and nRoot then
                        local d = (hrp.Position - nRoot.Position).Magnitude
                        if d < minDist then minDist = d; target = npc end
                    elseif nHum and nHum.Health > 0 and not nRoot then
                        unloadedMobPos = npc:GetPivot().Position
                    end
                end
            end
        end
        
        if target then
            local nRoot = target:FindFirstChild("HumanoidRootPart")
            local nHum = target:FindFirstChild("Humanoid")
            if nRoot and nHum then
                pcall(function() nHum.WalkSpeed = 0; nHum.JumpPower = 0; nRoot.CanCollide = false; nRoot.Velocity = Vector3.zero end)
                
                local goalCF = getFarmPosition(nRoot, S.farmDistance, S.farmPos)
                if (hrp.Position - goalCF.Position).Magnitude > 5000 then
                    S.lastPortal = "" -- Teleport failed! Reset memory so the script retries the portal instantly
                    task.wait(1)
                elseif (hrp.Position - goalCF.Position).Magnitude > 50 then
                    SmartTeleport(goalCF)
                else
                    hrp.CFrame = goalCF; hrp.Velocity = Vector3.zero
                    
                    if not char:GetAttribute("LastAttack") or tick() - char:GetAttribute("LastAttack") > 0.1 then
                        char:SetAttribute("LastAttack", tick())
                        
                        local weapons = getWeaponsToUse()
                        local loopWeapons = #weapons > 0 and weapons or {false}
                        for _, wep in ipairs(loopWeapons) do
                            if wep and typeof(wep) == "Instance" and wep.Parent ~= char then
                                pcall(function() hum:EquipTool(wep) end); task.wait(0.05)
                            end
                            executeAttacks(target)
                        end
                    end
                end
            end
        elseif unloadedMobPos then
            pcall(function() LocalPlayer:RequestStreamAroundAsync(unloadedMobPos) end)
            SmartTeleport(CFrame.new(unloadedMobPos + Vector3.new(0, 15, 0)))
        else
            if fbv then fbv:Destroy() end
            task.wait(0.5)
        end
    end
end)
